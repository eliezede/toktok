rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      // Notifications Subcollection
      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null; // Anyone authenticated can send notifications
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Helper functions
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Properties Collection
    match /properties/{propertyId} {
      // Anyone can see listings
      allow read: if true;
      
      // Only Agents or Agencies can create listings
      allow create: if request.auth != null 
                    && request.resource.data.createdBy == request.auth.uid
                    && (getUserData().role == 'agent' || getUserData().role == 'agency');
      
      // Update rules: Owner can edit all, others can only toggle likeCount
      allow update: if request.auth != null && (
        (resource.data.createdBy == request.auth.uid && request.resource.data.createdBy == resource.data.createdBy)
        ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']))
      );

      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }

    // Videos Collection (Tracking for Transcoding)
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
